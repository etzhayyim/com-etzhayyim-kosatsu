    "tadori (ADR-2605301400) — authorized on-chain tracing; a :designated-wallet/:designated-domain subject bridges to a tadori case (authorized only). kosatsu emits the join key, never the link.",
    "keizu (ADR-2606066000) — government power-relations weave; a :designated-org/:designated-entity that is also a public power role bridges to keizu (keizu's own G1 decides admissibility).",
    "tsumugi (ADR-2606011800) — power-entity 縁; each currently-listed designation projects an asserter→subject 'designation-power' influence edge.",
    "kanae (ADR-2605302300) — visualization; kosatsu emits the divergence/by-authority aggregates kanae can render.",
    "danjo (ADR-2605301600) — non-adjudicating discrepancy discipline; kosatsu reuses the no-verdict invariant.",
    "tasuke (ADR-2606060900) — cybercrime victim support is person-consented and disjoint; kosatsu NEVER auto-links a designation to a victim flow.",
    "chigiri (ADR-2605262700) — any legal characterization of a designation routes to external counsel; kosatsu never adjudicates."
  ],
  "cells": [
    { "name": "designation_ingest", "module": "magatama.cells.kosatsu_designation_ingest", "murakumoNode": "reuben", "phase": "continuous", "io": "an authority's PUBLIC designation export (OFAC SDN / EU consolidated / UN SC / UK OFSI / JP-MOF / Interpol public notices) → validated :authority/:subject/:designation datoms" },
    { "name": "competing_claim_weave", "module": "magatama.cells.kosatsu_competing_claim_weave", "murakumoNode": "gad", "phase": "continuous", "io": "the designation event log → per-subject divergence {contested|unanimous|single-asserter} + coverage-split + as-of status + by-authority + co-designation" },
    { "name": "social_post", "module": "magatama.cells.kosatsu_social_post", "murakumoNode": "naphtali", "phase": "periodic (event)", "io": "a divergence finding → dry-run networkPost (member-signed, competing-claim disclaimer, ≥2 primary sources); live post Council Lv6+ + operator gated" }
