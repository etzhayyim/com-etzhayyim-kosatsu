{:lexicon 1
 :id "com.etzhayyim.kosatsu.networkPost"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :description "A DRY-RUN social post projecting an aggregate kosatsu finding (a divergence/agreement summary). G8 INVARIANT: status is :dry-run only (:published unrepresentable; live posting = Council Lv6+ + operator + member signature). G9: every post opens with the mirror/competing-claim disclaimer and never speaks AS an authority. G2: non-adjudicating — reports who-designated-whom + disagreement, never a verdict. G7: member-signed, server never signs (:serverHeldKey const false)."
   :record
   {:type "object"
    :required ["postId" "subject" "body" "status" "isMirror" "nonAdjudicatingNotice" "serverHeldKey" "sources"]
    :properties
    {:postId  {:type "string"}
     :subject {:type "string" :description "the aggregate finding narrated (a divergence/agreement summary)."}
     :body    {:type "string"}
     :status  {:type "string" :const "dry-run"
               :description "G8 INVARIANT — dry-run only; published is unrepresentable at R0 (outward-gated)."}
     :isMirror {:type "boolean" :const true
                :description "G9 INVARIANT — only true; opens with the mirror/competing-claim disclaimer, never speaks AS an authority."}
     :nonAdjudicatingNotice {:type "boolean" :const true
                             :description "G2 INVARIANT — only true."}
     :serverHeldKey {:type "boolean" :const false
                     :description "G7 INVARIANT — only false; the member signs, the server never does (ADR-2605231525)."}
     :author  {:type "string" :description "SBT-bound member DID; required for any (gated) live post."}
     :sources {:type "array" :items {:type "string"} :minLength 2
               :description "G3 — the post carries the same ≥2 primary-source citations as the finding."}}}}}}
