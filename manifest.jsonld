  "gates": {
    "G1": "mirror-not-adjudicator — etzhayyim authors no designation; an authority kind/id resolving to self is unrepresentable; every designation carries assertedNotice const true (attributed)",
    "G2": "asserter-mandatory + non-adjudicating — no asserter-less 'global truth' designation; the measure is the authority's instrument (asset-freeze/export-control/…), never a verdict (criminal/guilty/terrorist unrepresentable)",
    "G3": "primary-source-only — ≥2 of the authority's OWN primary-publication citations per designation; commercial screening terminals (WorldCheck/Refinitiv/Dow-Jones/…) are a prohibited citation (Rider §2(e))",
    "G4": "event-log / as-of — status :listed | :delisted only; a delisting is a NEW datom carrying :lifted-at; nothing is overwritten; no final/permanent/convicted state (非終末論)",
    "G5": "subject-dignity / no-doxxing — a subject exists only as the named target of a public official act, carrying only the authority-published identifier; private-life PII unrepresentable (encrypted off-graph, ADR-2605181100)",
    "G6": "stance-explicit — each authority declares its OWN jurisdiction/legal-regime stance, attributed; never etzhayyim's view",
    "G7": "no-server-key + no per-subject score — posts member-signed (serverHeldKey const false); there is no :subject/risk-score / :guilt / :threat-level; divergence computed on read (edge-primary)",
    "G8": "outward-gated — live list ingest + live posting = Council Lv6+ + operator + member signature; R0 dry-run; cells .solve() raise; ingest --live refused",
    "G9": "map-not-target / no-enforcement — outputs route to compliance-awareness / due-process visibility / de-risking; never a 'who-to-freeze/attack' target-list or enforcement instruction",
    "G10": "sourcing-honesty — :representative vs :authoritative declared on every datom; the committed seed is :representative (synthetic ids/labels)"
  },
  "nonGoals": {
    "N1": "NOT a sanctions-screening / compliance product (no pass/fail verdict on a subject; danjo/chigiri boundary)",
    "N2": "NOT a watchlist or a target-list (a competing-claim mirror by construction)",
    "N3": "NOT a per-subject risk / guilt / threat score (edge-primary; we never rate a subject)",
    "N4": "NOT an enforcement / asset-freeze / interdiction instrument (observation only; G9)",
    "N5": "NOT a doxxing vector — a subject carries only the authority-published identifier (G5)",
    "N6": "NOT an adopter of any one jurisdiction's stance — every designation stays attributed to its asserter (G1/G6)",
    "N7": "NOT a Kotoba/Datomic/SQL store (kotoba Datom log only; supersedes the legacy RisingWave sanctions/intel apps)",
    "N8": "NOT a commercial intelligence terminal (primary public record only; Rider §2(e))"
  },
